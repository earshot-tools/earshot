{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignore": [],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{js,mjs}",
        "tools/eslint-workspace.config.js",
        "tools/eslint-base.config.js",
        "tools/vitest-base.config.js",
        "tools/dependency-cruiser-base.cjs"
      ],
      "project": ["scripts/**/*.{js,mjs}", "tools/**/*.{js,cjs,mjs}"],
      "ignoreBinaries": ["stryker", "tools/lint-staged-eslint.sh"],
      "ignoreDependencies": [
        "@earshot-tools/earshot-plugin",
        "@secretlint/secretlint-rule-preset-recommend",
        "stylelint-config-recommended"
      ]
    },
    "plugin": {},
    "shared": {}
  }
}
