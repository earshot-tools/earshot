{
  "openapi": "3.1.0",
  "info": {
    "title": "earshot",
    "version": "0.1.0",
    "description": "Local-only botless meeting capture, transcription, and speaker labeling for Obsidian on macOS.",
    "contact": {
      "name": "Inoyatov Khamidulla"
    },
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Same-origin (default)"
    }
  ],
  "tags": [
    {
      "name": "API",
      "description": "Default API surface"
    }
  ],
  "components": {
    "schemas": {
      "Hello": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "message"
        ],
        "additionalProperties": false
      },
      "Health": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          }
        },
        "required": [
          "status"
        ],
        "additionalProperties": false
      },
      "EchoRequest": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        },
        "required": [
          "message"
        ],
        "additionalProperties": false
      },
      "EchoResponse": {
        "type": "object",
        "properties": {
          "echoed": {
            "type": "string"
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "echoed",
          "receivedAt"
        ],
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          }
        },
        "required": [
          "type",
          "title",
          "status"
        ],
        "additionalProperties": false
      }
    }
  },
  "paths": {
    "/": {
      "get": {
        "operationId": "root",
        "tags": [
          "API"
        ],
        "summary": "Returns a hello-world greeting.",
        "description": "Returns a hello-world greeting.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Hello"
                },
                "examples": {
                  "default": {
                    "value": {
                      "message": "Hello, world!"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "406": {
            "description": "Not Acceptable — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "health",
        "tags": [
          "API"
        ],
        "summary": "Liveness probe.",
        "description": "Liveness probe.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                },
                "examples": {
                  "default": {
                    "value": {
                      "status": "ok"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "406": {
            "description": "Not Acceptable — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/echo": {
      "post": {
        "operationId": "echo",
        "tags": [
          "API"
        ],
        "summary": "Echoes the request body back with a server timestamp.",
        "description": "Echoes the request body back with a server timestamp.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                },
                "examples": {
                  "default": {
                    "value": {
                      "echoed": "ping",
                      "receivedAt": "2026-01-01T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "406": {
            "description": "Not Acceptable — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EchoRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "message": "ping"
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "echoPut",
        "tags": [
          "API"
        ],
        "summary": "Idempotent variant of POST /echo. Same semantics; demonstrates non-POST writes.",
        "description": "Idempotent variant of POST /echo. Same semantics; demonstrates non-POST writes.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                },
                "examples": {
                  "default": {
                    "value": {
                      "echoed": "pong",
                      "receivedAt": "2026-01-01T00:00:00.000Z"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "406": {
            "description": "Not Acceptable — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EchoRequest"
              },
              "examples": {
                "default": {
                  "value": {
                    "message": "pong"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/echo/{id}": {
      "delete": {
        "operationId": "echoDelete",
        "tags": [
          "API"
        ],
        "summary": "No-op delete. Demonstrates path parameters + 204 No Content.",
        "description": "No-op delete. Demonstrates path parameters + 204 No Content.",
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "406": {
            "description": "Not Acceptable — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error — RFC 7807 Problem Details",
            "content": {
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  }
}
