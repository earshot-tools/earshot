{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schema.json",
  "threshold": 0.5,
  "reporters": ["console"],
  "absolute": true,
  "gitignore": true,
  "format": ["typescript", "javascript", "tsx", "jsx"],
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.spec.ts",
    "**/*.stories.tsx",
    "**/migrations/**",
    "**/drizzle/**",
    "**/.storybook/**",
    "**/main.tsx",
    "**/.venv/**",
    "diarizer/.venv/**"
  ],
  "minLines": 5,
  "minTokens": 50
}
